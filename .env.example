# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key   # needed for webhook to bypass RLS

# AI providers — power food photo analysis, recipe import, and the Help assistant.
# callAI() tries them in order (all free, no card) and falls back on the next:
#   1. Gemini  (~1,500/day) — aistudio.google.com/app/apikey  (key: AIza...)
#   2. Groq    (~1,000/day) — console.groq.com/keys           (key: gsk_...)
#   3. OpenRouter (~50/day) — openrouter.ai/keys              (key: sk-or-v1-...)
# Set at least one. Gemini gives the most headroom; Groq is the reliable fallback.
GEMINI_API_KEY=AIza...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-v1-...

# Stripe — OPTIONAL (only if Premium subscriptions are enabled).
# Leave blank for a free-only build. Get keys from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...        # or sk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...      # from Stripe webhook settings
STRIPE_PRICE_ID=price_...            # recurring price ID for the premium plan
PUBLIC_URL=https://www.dagnara.com   # used for Stripe redirect URLs

PORT=3000
