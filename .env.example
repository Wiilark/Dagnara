# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key   # needed for webhook to bypass RLS

ANTHROPIC_API_KEY=sk-ant-...

# Stripe — get keys from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...        # or sk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...      # from Stripe webhook settings
STRIPE_PRICE_ID=price_...            # recurring price ID for the premium plan
PUBLIC_URL=https://9ysummpd.up.railway.app  # used for Stripe redirect URLs

# Nutritionix — restaurant food database (free tier: 500 req/day)
# Register at developer.nutritionix.com
NUTRITIONIX_APP_ID=your-app-id
NUTRITIONIX_API_KEY=your-api-key

PORT=3000
