EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-supabase-anon-key

# Deploy server.js to Railway/Render/Fly.io and set this to your production URL.
EXPO_PUBLIC_API_URL=https://your-backend.railway.app

# Register a free USDA FoodData Central key at https://fdc.nal.usda.gov/api-guide.html
# DEMO_KEY = 30 req/hr per IP (sufficient for dev). A registered key removes the cap.
EXPO_PUBLIC_USDA_KEY=DEMO_KEY
