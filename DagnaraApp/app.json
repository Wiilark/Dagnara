{
  "expo": {
    "name": "Dagnara",
    "slug": "dagnara",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c0818"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dagnara.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Dagnara uses your camera to identify food items and estimate their nutritional content.",
        "NSPhotoLibraryUsageDescription": "Dagnara accesses your photo library so you can select food photos for nutritional analysis.",
        "NSHealthShareUsageDescription": "Dagnara reads your steps, active calories, and sleep from Apple Health to show your daily activity.",
        "NSHealthUpdateUsageDescription": "Dagnara writes your logged workouts and calories burned to Apple Health."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0c0818"
      },
      "package": "com.dagnara.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_SLEEP_SESSION",
        "android.permission.health.WRITE_EXERCISE_SESSION"
      ]
    },
    "plugins": [
      "expo-router",
      "react-native-health",
      ["react-native-health-connect", {
        "permissions": ["ReadSteps", "ReadActiveCaloriesBurned", "ReadSleepSession", "WriteExerciseSession"]
      }],
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "Dagnara accesses your photo library so you can select food photos for nutritional analysis."
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0c0818"
        }
      ]
    ],
    "scheme": "dagnara",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b6c130fe-5515-43e1-9427-098eb2b7979c"
      }
    },
    "owner": "dagnara"
  }
}
